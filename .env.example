# Copy this file to .env and fill in values for your environment.

# Ollama-compatible chat API. For local Ollama use http://localhost:11434.
# For Ollama Cloud, replace this with the base URL provided by your account.
OLLAMA_API_BASE=https://ollama.com
OLLAMA_API_KEY=replace-with-your-ollama-cloud-key
OLLAMA_MODEL=replace-with-your-ollama-model

# Local retrieval settings.
# Use local-hash for a fast no-download demo. For better semantic retrieval, switch to:
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL=local-hash
CHROMA_PATH=chroma_db
CHROMA_COLLECTION=document_qa
CHUNK_SIZE=900
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=4
MIN_RELEVANCE_SCORE=0.25
